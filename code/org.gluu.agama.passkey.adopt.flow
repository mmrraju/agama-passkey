//  Shows a nudge screen if the user has no passkeys and has not recently snoozed.
Flow org.gluu.agama.passkey.adopt
     Basepath ""
     Inputs userData conf
//  Extract uid and inum from userData
uid = userData.uid
inum = userData.inum
snoozeDays = conf.snoozeDays
//  Read snoozeDays from conf, default to 7
When snoozeDays is null
     snoozeDays = 7
// Check how many passkeys the user has enrolled
passkeyCount = 0
//  Check how many passkeys the user has enrolled.
mfaInfo | E = Call org.gluu.agama.passkey.EnrollmentHelper#new 
When E is null
     mfaData | E2 = Call mfaInfo getMFAUserInfoByFido2 uid
     When E2 is null
          passkeyCount = mfaData.count
//  If user already has passkeys, skip nudge entirely
When passkeyCount is not 0
     it_loetq = {success:true, data: { userId: uid }}
     Finish it_loetq
//  Check if user has an active snooze
snoozed = Call org.gluu.agama.passkey.NudgeHelper#isSnoozed uid snoozeDays
When snoozed is true
     it_ztxpv = {success:true, data: { userId: uid }}
     Finish it_ztxpv
//  Show the nudge screen
nudgeForm = RRF "passkey-nudge.ftlh" 
When nudgeForm.addPasskeyNowBtn is ""
     //  User wants to add a passkey — trigger the add flow
     addTrigger = Trigger org.gluu.agama.passkey.add userData
     it_hxwqv = {success:true, data: { userId: uid }}
     Finish it_hxwqv
When nudgeForm.remindLaterBtn is ""
     //  User wants to be reminded later — record snooze and continue
     Call org.gluu.agama.passkey.NudgeHelper#snooze snoozeDays
     it_oproh = {success:true, data: { userId: uid }}
     Finish it_oproh
//  Fallback finish (should not be reached)
it_tahyq = {success:true, data: { userId: uid }}
Finish it_tahyq