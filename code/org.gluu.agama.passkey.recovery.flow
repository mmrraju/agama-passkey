Flow org.gluu.agama.passkey.recovery
     Basepath ""
startObj = { username: "", showError: false, errorMessage: "" }
// Max tries
Repeat 3 times max
     // Call agama-smtp flow.
     smtpResult = Trigger org.gluu.agama.smtp.main 
     userData = Call org.gluu.agama.passkey.IdentityProcessor#accountFromUid smtpResult.userId
     // Trigger passkey enrollment
     addResult = Trigger org.gluu.agama.passkey.add userData
     // Flow finish
     it_dapcl = {success:true, data: { userId: addResult.userId}}
     Finish it_dapcl
// Exceeded max attempts
it_fyiil = {success:false, error: "Recovery attempt exceeded"}
Finish it_fyiil