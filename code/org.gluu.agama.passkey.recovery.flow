Flow org.gluu.agama.passkey.recovery
     Basepath ""
startObj = { username: "", showError: false, errorMessage: "" }
// Max tries
Repeat 3 times max
     // Call agama-smtp flow.
     userData = Trigger org.gluu.agama.smtp.main 
     // Trigger passkey enrollment
     addResult = Trigger org.gluu.agama.passkey.add userData
     // Flow finish
     it_dbpkb = {success:true, data: { userId: addResult.userId}}
     Finish it_dbpkb
// Exceeded max attempts
it_bfegt = {success:false, error: "Recovery attempt exceeded"}
Finish it_bfegt