Flow org.gluu.agama.passkey.recovery
     Basepath ""
// Recovery flow has been called
Log "@info Recovery flow has been called..."
startObj = { username: "", showError: false, errorMessage: "" }
// Max tries
Repeat 3 times max
     // Call agama-smtp flow.
     smtpResult | Esr = Trigger org.gluu.agama.smtp.main 
     Log "@info SMTP result %" smtpResult
     When Esr is not null
          // SMTP flow getting error
          Log "@info SMTP flow getting error"
          // Error in recovery
          it_oqkbh = {success:false, error: "Getting error while recovering."}
          Finish it_oqkbh
     userId = smtpResult.data.userId
     userData | Eu = Call org.gluu.agama.passkey.IdentityProcessor#accountFromUid userId
     // Trigger passkey enrollment
     addResult = Trigger org.gluu.agama.passkey.add userData
     // Flow finish
     it_qknvq = {success:true, data: { userId: addResult.userId}}
     Finish it_qknvq
// Exceeded max attempts
it_qolzu = {success:false, error: "Recovery attempt exceeded"}
Finish it_qolzu